{"id":"a74ecf4f811f939703cff1e1e09cbbf24c2d831a9938e5ddd8f479004af722f0","source":"support-chat","type":"conversation","payload":{"messages":[{"role":"user","content":"One more — please default to async examples. Our codebase is fully async (FastAPI + asyncpg)."},{"role":"assistant","content":"Noted. I'll default to AsyncStatewaveClient in any code I show you."}]},"metadata":{"imported_at":"2026-05-06T15:25:18.783210+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null},"provenance":{"imported_at":"2026-05-06T15:25:18.783202+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null,"content_hash":"a74ecf4f811f939703cff1e1e09cbbf24c2d831a9938e5ddd8f479004af722f0"},"created_at":"2026-05-06T15:25:18.783400+00:00"}
{"id":"f0663434e364076adf2057e97e1b91dd9058efe52eb441b3d41e171d556eeb9e","source":"support-chat","type":"conversation","payload":{"messages":[{"role":"user","content":"Setting up webhooks. Our pattern at Northwind is hooks.northwind-logistics.fr/<service>/<event-type>. Is that supported?"},{"role":"assistant","content":"Yes — Statewave POSTs to whatever URL you register, no path constraints. I'd suggest hooks.northwind-logistics.fr/statewave/<event-type>. Noted as your standard pattern so I won't suggest different URL shapes later."}]},"metadata":{"imported_at":"2026-05-06T15:25:18.783210+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null},"provenance":{"imported_at":"2026-05-06T15:25:18.783202+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null,"content_hash":"f0663434e364076adf2057e97e1b91dd9058efe52eb441b3d41e171d556eeb9e"},"created_at":"2026-05-06T15:25:18.783385+00:00"}
{"id":"3e92af320a1dcf6f32f0607c225a7d9e02b485a9943d5238f585ebac8fd11a06","source":"support-chat","type":"conversation","payload":{"messages":[{"role":"user","content":"Volume question — we'll be writing roughly 500k shipment-events per month. Is that fine on the Team plan?"},{"role":"assistant","content":"500k episodes/month is well within the Team plan's headroom. Recommended pattern: one subject per active driver-route, archive after 90 days. I've noted your projected volume so future capacity questions reference it."}]},"metadata":{"imported_at":"2026-05-06T15:25:18.783210+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null},"provenance":{"imported_at":"2026-05-06T15:25:18.783202+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null,"content_hash":"3e92af320a1dcf6f32f0607c225a7d9e02b485a9943d5238f585ebac8fd11a06"},"created_at":"2026-05-06T15:25:18.783368+00:00"}
{"id":"6af48f09d5f1068b74c6324b9de881c7f6d351b466e176b8f4d457d1785d49f2","source":"support-chat","type":"conversation","payload":{"messages":[{"role":"user","content":"Hi — Maya from Northwind Logistics. We just signed up for the Team plan. I run the dispatch-automation team here in Paris. We're planning to use Statewave to give our routing copilot memory across drivers and shipments."},{"role":"assistant","content":"Welcome, Maya! Glad to have Northwind on board. I've noted your use case — dispatch automation for routing — so future answers can lean on it. Anything blocking your first ingest?"},{"role":"user","content":"We'll be in Python. Strong preference for typed SDKs — we run mypy --strict everywhere."},{"role":"assistant","content":"Got it. The Python SDK ships full Pydantic models and type stubs; mypy --strict should pass clean. I'll keep examples in Python with explicit types when answering you."}]},"metadata":{"imported_at":"2026-05-06T15:25:18.783210+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null},"provenance":{"imported_at":"2026-05-06T15:25:18.783202+00:00","original_subject_id":"_build_demo_pack_demo-support-agent","imported_from_export_id":null,"content_hash":"6af48f09d5f1068b74c6324b9de881c7f6d351b466e176b8f4d457d1785d49f2"},"created_at":"2026-05-06T15:25:18.783346+00:00"}
